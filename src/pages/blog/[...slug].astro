---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { formatDate } from "@/lib/date";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await render(post);
---

<Layout>
  <a href="/blog" class="back-link">← all posts</a>
  <div class="post-header">
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      <span>{formatDate(post.data.date)}</span>
    </div>
  </div>
  <article class="post-content">
    <Content />
  </article>
</Layout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.75rem;
    color: var(--text-dim);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.15s;
  }

  .post-header {
    padding-bottom: 1.5rem;
    margin-bottom: 0;
  }

  .post-header h1 {
    color: var(--text-bright);
    margin-bottom: 0.5rem;
  }

  .post-meta {
    color: var(--text-dim);
    font-size: 0.75rem;
    display: flex;
    gap: 1rem;
  }

  .post-content {
    padding-bottom: 2rem;
  }

  .post-content p {
    font-weight: 300;
    margin-bottom: 1.25rem;
    line-height: 1.8;
  }

  .post-content h2 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-content h3 {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-content a {
    color: var(--text-bright);
    text-decoration: underline;
    text-underline-offset: 0.2rem;
    text-decoration-color: var(--border);
    transition: text-decoration-color 0.15s;
  }

  .post-content a:hover {
    background: none;
    text-decoration-color: var(--text-dim);
  }

  .post-content strong {
    font-weight: 500;
    color: var(--text-bright);
  }

  .post-content em {
    font-style: italic;
    color: var(--text);
  }

  .post-content pre {
    background: var(--code-bg, var(--bg));
    border: 1px solid var(--border);
    padding: 1.25rem 1.5rem;
    margin: 1.5rem -2rem;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--text);
  }

  .post-content code {
    font-family: var(--mono, monospace);
    font-size: 0.875rem;
  }

  .post-content p code {
    background: var(--code-bg, var(--bg));
    border: 1px solid var(--border);
    padding: 0.125rem 0.375rem;
    font-size: 0.8rem;
    color: var(--text-bright);
  }

  .post-content ul {
    list-style: none;
    margin-bottom: 1.25rem;
    padding-left: 0;
  }

  .post-content ul li {
    font-weight: 300;
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.375rem;
  }

  .post-content ul li::before {
    content: "·";
    position: absolute;
    left: 0.25rem;
    color: var(--text-dim);
  }

  .post-content blockquote {
    border-left: 2px solid var(--border);
    padding-left: 1rem;
    color: var(--text-dim);
    font-style: italic;
    font-weight: 300;
    margin: 1.5rem 0;
  }

  .post-content hr {
    margin: 2.25rem 0;
  }

  @media (max-width: 560px) {
    .post-header h1 {
      font-size: 1.25rem;
    }

    .post-header {
      padding-bottom: 1.25rem;
      margin-bottom: 1.25rem;
    }

    .post-content pre {
      margin-left: -1rem;
      margin-right: -1rem;
      padding: 1rem;
    }
  }
</style>
